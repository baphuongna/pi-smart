{
  "name": "pi-smart",
  "version": "0.1.1",
  "description": "Pi extension for output filtering, compression, analyze tool, and cost tracking",
  "author": "baphuongna",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "smart",
    "filter",
    "compression",
    "cost-tracking"
  ],
  "files": [
    "*.ts",
    "src/**/*.ts",
    "skills/**/*",
    "AGENTS.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test --test-concurrency=1 --test-timeout=30000 test/unit/*.test.ts",
    "ci": "npm run typecheck && npm test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "typescript": "^5.9.3"
  }
}