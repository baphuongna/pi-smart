{
  "name": "pi-smart",
  "version": "0.4.5",
  "description": "Extension for Pi coding agent",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    }
  },
  "files": [
    "*.ts",
    "*.mjs",
    "src/**/*.ts",
    "skills/**/*",
    "README.md",
    "docs/",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "pi",
    "coding-agent",
    "extension"
  ],
  "author": "BaphuongNA",
  "license": "MIT",
  "repository": "https://github.com/baphuongna/pi-smart",
  "dependencies": {
    "vm2": "^3.9.19"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "@earendil-works/pi-coding-agent": ">=0.73.0"
  }
}
